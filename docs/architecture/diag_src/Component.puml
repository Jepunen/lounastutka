@startuml
!ENABLE_ALL_PLANT_ELEMENTS = 1
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
' src: https://github.com/plantuml-stdlib/C4-PlantUML
' C4 video: https://www.youtube.com/watch?v=x2-rSnhpw0g

' Boundary(alias, label, ?type, ?tags, ?link, ?descr) {
' Container(alias, label, ?techn, ?descr, ?sprite, ?tags, ?link, ?baseShape)
' Component(alias, label, ?techn, ?descr, ?sprite, ?tags, ?link, ?baseShape)
' ComponentDb(alias, label, ?techn, ?descr, ?sprite, ?tags, ?link)
' ComponentQueue(alias, label, ?techn, ?descr, ?sprite, ?tags, ?link)
' Component_Ext(alias, label, ?techn, ?descr, ?sprite, ?tags, ?link, ?baseShape)
' ComponentDb_Ext(alias, label, ?techn, ?descr, ?sprite, ?tags, ?link)
' ComponentQueue_Ext(alias, label, ?techn, ?descr, ?sprite, ?tags, ?link)

Container(fe, "SPA Frontend", "React", "Provides the user a mapview with different restaurants and their menus.")
ContainerDb(db, "Application Content Database", "PostgreSQL", "Stores restaurant, user and authentication related information.")
Container(ms, "Menu Data Microservice", "Python", "Fetches and parses menu information from restaurant websites, serving them to the backend.")

Boundary(be, "Web Application Backend", "Bun.js, Express", "", ?link, "Handles requests and data flow between different services.") {
	Component(uaCtrl, "User Authentication Controller", "HTTPS/JSON", "HTTP endpoint for user registration and login.")
	Component(uaServ, "Authentication Service", "Typescript", "Checks users passwords and/or passkeys and creates challenges.")
	Component(proCtrl, "Protected Controller", "HTTPS/JSON", "HTTP endpoint for authenticated user privileged access.")
	Component(proSess, "Protected Session Service", "Typescript", "Verifies users JWT session token.")
	Component(intApi, "Internal API", "Typescript", "Used in microservice architecture interfaces for communication with different parts of the internal system.")
}

' Rel(personAlias, containerAlias, "Label", "Optional Technology")
Rel(uaCtrl, uaServ, "authenticates user with", "Typescript")
Rel(fe, uaCtrl, "makes API calls to", "HTTPS/JSON")
Rel(fe, proCtrl, "makes API calls to", "HTTPS/JSON")
Rel(proCtrl, proSess, "verifies users session with", "HTTPS/JSON")

Rel(intApi, ms, "makes calls to", "")
Rel(intApi, db, "makes queries to", "")
Rel(uaServ, intApi, "uses for database access", "")


SHOW_LEGEND()

@enduml
