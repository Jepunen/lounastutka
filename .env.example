# Copy this file to .env and fill in the values
# .env is gitignored and must never be committed

# PostgreSQL
POSTGRES_USER=lounastutka
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lounastutka
POSTGRES_HOST=db
DB_PORT=5432

# JWT Bearer token authentication
JWT_SECRET=super_jwt_secret

# Relay Party stuff:
APP_HOST=lounastutka.local.org
WEBAUTHN_RP_ID=lounastutka.local.org
WEBAUTHN_RP_NAME=Lounastutka
WEBAUTHN_ORIGIN=https://lounastutka.local.org

# Grafana
GF_ADMIN_PASSWORD=changeme
